{
  "name": "homewise",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:backend": "turbo run build --filter @homewise/backend-app --cwd ./apps/server",
    "build:web": "turbo run build --filter @homewise/web-app --cwd ./apps/web",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrations:create": "turbo run db:migrations:create",
    "db:migrations:apply": "turbo run db:migrations:apply",
    "db:studio": "turbo run db:studio"
  },
  "dependencies": {
    "hono": "catalog:"
  },
  "devDependencies": {
    "@homewise/typescript-config": "workspace:*",
    "@types/react": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "turbo": "^2.9.6",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  }
}
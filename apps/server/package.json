{
  "name": "@homewise/server",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "type": "./src/index.ts"
    },
    "./households": {
      "import": "./src/modules/households/models/index.ts",
      "type": "./src/modules/households/models/index.ts"
    },
    "./child-dictionaries": {
      "import": "./src/modules/child-dictionaries/models/index.ts",
      "type": "./src/modules/child-dictionaries/models/index.ts"
    },
    "./child-profiles": {
      "import": "./src/modules/child-profiles/models/index.ts",
      "type": "./src/modules/child-profiles/models/index.ts"
    },
    "./pet-profiles": {
      "import": "./src/modules/pet-profiles/models/index.ts",
      "type": "./src/modules/pet-profiles/models/index.ts"
    },
    "./contacts": {
      "import": "./src/modules/contacts/models/index.ts",
      "type": "./src/modules/contacts/models/index.ts"
    },
    "./medical": {
      "import": "./src/modules/medical/models/index.ts",
      "type": "./src/modules/medical/models/index.ts"
    }
  },
  "scripts": {
    "db:up": "docker compose up -d",
    "db:studio": "drizzle-kit studio",
    "db:migrations:create": "drizzle-kit generate",
    "db:migrations:apply": "drizzle-kit migrate",
    "dev": "tsx watch ./src/index.ts",
    "build": "tsc && tsc-alias -f",
    "build:vercel": "bash ./scripts/vercel-build.sh",
    "db:seed": "tsx ./src/db/seed.ts",
    "check-types": "tsc --noEmit",
    "emails:preview": "email dev --port 4000"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@hono/zod-validator": "catalog:",
    "@neondatabase/serverless": "catalog:",
    "@vercel/blob": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "resend": "catalog:",
    "sharp": "catalog:"
  },
  "devDependencies": {
    "@homewise/typescript-config": "workspace:*",
    "@react-email/ui": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@types/react-dom": "catalog:",
    "drizzle-kit": "catalog:",
    "pg": "catalog:",
    "react-email": "catalog:",
    "tsc-alias": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  }
}
